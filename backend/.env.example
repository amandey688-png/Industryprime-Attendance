SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Required for auth/JWT validation:
SUPABASE_ANON_KEY=

# FastAPI runs with CORS already configured for Next.js dev.
# Production frontend URL, e.g. https://your-app.vercel.app
FRONTEND_URL=
# Or comma-separated origins, e.g. https://a.vercel.app,https://b.vercel.app
CORS_ORIGINS=

# Default API port for local Next.js integration. Match web/.env.local NEXT_PUBLIC_API_URL.
API_PORT=8000

# Required for FastAPI-issued JWTs. Use a long random value in production.
JWT_SECRET=
DECISION_TOKEN_SECRET=

# Signup OTP: for production, run `backend/database/otp_schema.sql` in Supabase (pending_signups, otp_codes).
# If those tables are missing, the API falls back to a signed browser ticket (still requires `users` table).
# Outbound OTP email needs SMTP on the API host unless EMAIL_MODE=log (then OTP is logged only, not sent).

# --- Email: Postmark SMTP only (no HTTPS API; same flow local + production) ---
# Set on the **API host** (Render/Railway/backend/.env), not Vercel. Supabase Auth → SMTP does NOT apply here.
# Postmark: use Server API token as SMTP password; username is often the same token or your PM-T-… from Postmark.
#
# Render recommended set:
#   POSTMARK_SMTP_HOST=smtp.postmarkapp.com
#   POSTMARK_SMTP_PORT=587
#   POSTMARK_SMTP_USERNAME=<server token or PM-T-…>
#   POSTMARK_SMTP_TOKEN=<same server token if Postmark shows one value for both>
#   SMTP_FROM_EMAIL=verified-sender@yourdomain.com
# Optional: SMTP_POSTMARK_STREAM=outbound
# Remove unused vars: POSTMARK_SERVER_TOKEN, POSTMARK_ACCESS_KEY (not read by this app).
#
# Until SMTP is configured: EMAIL_MODE=log (leave/OTP log only; no secrets required).
EMAIL_MODE=postmark
EMAIL_TEST_REDIRECT=
POSTMARK_SMTP_HOST=smtp.postmarkapp.com
POSTMARK_SMTP_PORT=587
POSTMARK_SMTP_USERNAME=
POSTMARK_SMTP_TOKEN=
SMTP_FROM_EMAIL=
POSTMARK_FROM_EMAIL=
SMTP_POSTMARK_STREAM=outbound
#
# Production email smoke (set vars on host; use real FRONTEND_URL for leave decision links):
# 1) POST /auth/signup/start — OTP email
# 2) Create leave request — email lists + SMTP above
# 3) POST /email-lists/test — same SMTP path (master_admin JWT)
#
# Start API (recommended): from `backend/` run  `python main.py`
# Or: `uvicorn main:app --reload --host 127.0.0.1 --port 8000`
# Or: `.\run.ps1`
