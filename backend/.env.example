SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Required for auth/JWT validation:
SUPABASE_ANON_KEY=

# FastAPI runs with CORS already configured for Next.js dev.
# Production frontend URL, e.g. https://your-app.vercel.app
FRONTEND_URL=
# Or comma-separated origins, e.g. https://a.vercel.app,https://b.vercel.app
CORS_ORIGINS=

# Default API port for local Next.js integration. Match web/.env.local NEXT_PUBLIC_API_URL.
API_PORT=8000

# Required for FastAPI-issued JWTs. Use a long random value in production.
JWT_SECRET=
DECISION_TOKEN_SECRET=

# Email delivery (Postmark)
POSTMARK_SERVER_TOKEN=
POSTMARK_SMTP_TOKEN=
POSTMARK_SMTP_USERNAME=
POSTMARK_SMTP_HOST=smtp.postmarkapp.com
POSTMARK_SMTP_PORT=587
POSTMARK_FROM_EMAIL=aman@industryprime.com
POSTMARK_MESSAGE_STREAM=outbound
#
# Production email smoke (set vars on host; use real FRONTEND_URL for leave decision links):
# 1) POST /auth/signup/start — OTP email (otp_email.html)
# 2) Create leave request — approver / notification templates (requires email lists + DB)
# 3) POST /email-lists/test — SMTP ping (master_admin JWT; optional ?to_email=)
#
# Start API (recommended): from `backend/` run  `python main.py`
# Or: `uvicorn main:app --reload --host 127.0.0.1 --port 8000`
# Or: `.\run.ps1`
