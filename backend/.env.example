SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Required for auth/JWT validation:
SUPABASE_ANON_KEY=

# FastAPI runs with CORS already configured for Next.js dev.
# Production frontend URL, e.g. https://your-app.vercel.app
FRONTEND_URL=
# Or comma-separated origins, e.g. https://a.vercel.app,https://b.vercel.app
CORS_ORIGINS=

# Default API port for local Next.js integration. Match web/.env.local NEXT_PUBLIC_API_URL.
API_PORT=8000

# Required for FastAPI-issued JWTs. Use a long random value in production.
JWT_SECRET=
DECISION_TOKEN_SECRET=

# Signup OTP: for production, run `backend/database/otp_schema.sql` in Supabase (pending_signups, otp_codes).
# If those tables are missing, the API falls back to a signed browser ticket (still requires `users` table).
# Outbound OTP email needs Postmark on the API host unless EMAIL_MODE=log (then OTP is logged only, not sent).

# Email delivery (Postmark). Set these on the **API host** (Render/Railway/etc.), not only Vercel.
# NOT the same as Supabase Dashboard → Authentication → SMTP (that only powers Supabase Auth emails).
# POSTMARK_FROM_EMAIL must be a verified Sender Signature or domain in Postmark.
#
# Until Postmark is on the API host, use log-only mode (no token required; leave/OTP/test succeed and log):
#   EMAIL_MODE=log
# Leave requests still save if Postmark is missing; emails are skipped and the API returns delivery_note (UI).
# With Postmark configured, send everything to one inbox (staging / smoke tests):
#   EMAIL_TEST_REDIRECT=you@yourcompany.com
EMAIL_MODE=postmark
EMAIL_TEST_REDIRECT=
POSTMARK_SERVER_TOKEN=
POSTMARK_SMTP_TOKEN=
POSTMARK_SMTP_USERNAME=
POSTMARK_SMTP_HOST=smtp.postmarkapp.com
POSTMARK_SMTP_PORT=587
POSTMARK_FROM_EMAIL=aman@industryprime.com
POSTMARK_MESSAGE_STREAM=outbound
# Timeout (seconds) for Postmark HTTPS API calls.
POSTMARK_API_TIMEOUT=30
# auto = try HTTPS API first (recommended in production if SMTP is blocked), then SMTP.
# smtp = SMTP only.  api = Postmark REST only (uses POSTMARK_SERVER_TOKEN or POSTMARK_SMTP_TOKEN).
POSTMARK_DELIVERY=auto
# Use a **live** server token on production; Postmark "Server API token (test)" does not inbox real addresses.
#
# Production email smoke (set vars on host; use real FRONTEND_URL for leave decision links):
# 1) POST /auth/signup/start — OTP email (otp_email.html)
# 2) Create leave request — approver / notification templates (requires email lists + DB)
# 3) POST /email-lists/test — same send path as leave (master_admin JWT); with EMAIL_MODE=log, check API logs
#
# Start API (recommended): from `backend/` run  `python main.py`
# Or: `uvicorn main:app --reload --host 127.0.0.1 --port 8000`
# Or: `.\run.ps1`
