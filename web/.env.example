# Public browser base: full http(s) URL of FastAPI when it matches the app origin; otherwise the app uses same-origin `/api`.
# Must start with http:// or https:// — never a Windows path (e.g. not C:\... or paths to .sql files).
NEXT_PUBLIC_API_URL=https://industryprime-attendance.onrender.com

# Optional: server-only proxy target (Vercel / Node). If unset, `NEXT_PUBLIC_API_URL` is used when it is an absolute http(s) URL.
# Must be http(s) only — not a file path.
# BACKEND_PROXY_TARGET=https://industryprime-attendance.onrender.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
