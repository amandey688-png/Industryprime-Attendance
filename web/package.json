{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true,maxRetries:10,retryDelay:250});console.log('Removed .next');}catch(e){console.warn('clean:next:',e?.code||e?.message)}\"",
    "dev": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next dev --webpack --port 3000",
    "dev:fresh": "npm run clean:next && npm run dev",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "prebuild": "npm run pwa:icons",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test:ci": "npm run lint && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.2",
    "next-pwa": "^5.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
